# Required: Your ZIdentity (OneAPI) OAuth Client ID
ZSCALER_CLIENT_ID=your_client_id_here

# Required: Your ZIdentity (OneAPI) OAuth Client Secret
ZSCALER_CLIENT_SECRET=your_client_secret_here

# Required: Your Zscaler Vanity Domain (e.g., if you login at https://mycompany.zslogin.net, it's 'mycompany')
ZSCALER_VANITY_DOMAIN=your_vanity_domain_here

# Optional: The specific ZIA API endpoint (Defaults to api.zsapi.net)
# ZSCALER_API_URL=api.zscalerthree.net

# Optional: The name of the IP Destination Group to create/update
# TARGET_GROUP_NAME="AI Guard Destinations"